---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch the index page entry from the content collection
const entry = await getEntry('pages', 'index');

if (!entry) {
  throw new Error("Could not find 'index' entry in pages content collection. Please ensure src/content/pages/index.md exists.");
}

const { Content } = await render(entry);
const { title, description, h1, type, service, landmarks } = entry.data;
---

<Layout
  title={title}
  description={description}
  h1={h1}
  type={type}
  service={service}
  landmarks={landmarks}
>
  <Content />
</Layout>
